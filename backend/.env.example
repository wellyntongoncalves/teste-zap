PORT=3000

# --- Banco de dados ---
# Produção (Vercel + Supabase/Neon): use apenas DATABASE_URL (com SSL).
# Pegue a "Connection string" no painel do Supabase (use a do POOLER, porta 6543).
# Ex: postgresql://postgres.xxxx:SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Local/Docker/testes: se DATABASE_URL estiver vazio, usa estas variáveis.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=finance_whatsapp
DB_USER=postgres
DB_PASSWORD=postgres
# Force SSL mesmo sem DATABASE_URL (normalmente deixe em branco no local).
DB_SSL=

JWT_SECRET=troque-este-valor-por-um-segredo-forte
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN_DAYS=30

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# --- Integração com Obsidian ---
#
# LOCAL: grava as notas direto na pasta do vault no seu PC.
# Caminho absoluto/relativo para a pasta do vault (ex: ../vault).
# Deixe em branco para desativar. No Vercel isto NÃO funciona (o servidor não
# enxerga a pasta do seu PC) — use as variáveis VAULT_REPO/GITHUB_TOKEN abaixo.
OBSIDIAN_VAULT_PATH=../vault

# NUVEM (Vercel): grava as notas num repositório Git via API do GitHub. O seu
# Obsidian local sincroniza esse repo com o plugin "Obsidian Git".
# VAULT_REPO no formato "usuario/repo"; GITHUB_TOKEN é um Personal Access Token
# (fine-grained) com permissão de escrita em "Contents" nesse repositório.
VAULT_REPO=
VAULT_BRANCH=main
GITHUB_TOKEN=
