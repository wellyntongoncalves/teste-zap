PORT=3000

# --- Banco de dados ---
# Produção (Vercel + Supabase/Neon): use apenas DATABASE_URL (com SSL).
# Pegue a "Connection string" no painel do Supabase (use a do POOLER, porta 6543).
# Ex: postgresql://postgres.xxxx:SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Local/Docker/testes: se DATABASE_URL estiver vazio, usa estas variáveis.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=finance_whatsapp
DB_USER=postgres
DB_PASSWORD=postgres
# Force SSL mesmo sem DATABASE_URL (normalmente deixe em branco no local).
DB_SSL=

JWT_SECRET=troque-este-valor-por-um-segredo-forte
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN_DAYS=30

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Caminho absoluto para a pasta do vault do Obsidian (ex: ../vault).
# Deixe em branco para desativar a sincronização de gastos como notas.
# OBS: no Vercel (nuvem) isto NÃO funciona — o servidor não enxerga a pasta do
# seu PC. Deixe em branco na nuvem; use só no backend rodando localmente.
OBSIDIAN_VAULT_PATH=../vault
